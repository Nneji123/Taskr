# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5001

# PostgreSQL
POSTGRES_USER=taskr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=taskr
DATABASE__CONNECTIONSTRING=Host=postgres;Port=5432;Database=taskr;Username=taskr;Password=changeme

# Redis
REDIS__CONNECTIONSTRING=redis:6379

# JWT (generate with: openssl rand -base64 64)
JWT__SECRET=replace-with-a-64-char-base64-secret
JWT__ISSUER=taskr-api
JWT__AUDIENCE=taskr-clients
JWT__ACCESSTOKENLIFETIMEMINUTES=15
JWT__REFRESHTOKENLIFETIMEDAYS=7

# CORS
CORS__ALLOWEDORIGINS__0=http://localhost:3000

# Sentry (optional — leave empty to disable)
SENTRY__DSN=

# SMTP (dev: mailpit, prod: your SMTP provider)
EMAIL__SMTP__HOST=mailpit
EMAIL__SMTP__PORT=1025
EMAIL__SMTP__USETLS=false
EMAIL__SMTP__USERNAME=
EMAIL__SMTP__PASSWORD=
EMAIL__SMTP__FROM=noreply@taskr.local
EMAIL__SMTP__FROMNAME=Taskr

# Storage (local | s3 | cloudinary)
STORAGE__PROVIDER=local
# S3 (when STORAGE__PROVIDER=s3)
STORAGE__S3__BUCKETNAME=
STORAGE__S3__REGION=us-east-1
STORAGE__S3__ACCESSKEY=
STORAGE__S3__SECRETKEY=
# Cloudinary (when STORAGE__PROVIDER=cloudinary)
STORAGE__CLOUDINARY__CLOUDNAME=
STORAGE__CLOUDINARY__APIKEY=
STORAGE__CLOUDINARY__APISECRET=
